{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/krillinai/growth-skills/schemas/evals.schema.json",
  "title": "Growth Skill Evaluation Specification",
  "type": "object",
  "required": ["skill_name", "evals"],
  "additionalProperties": false,
  "properties": {
    "skill_name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "evals": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/eval"}
    }
  },
  "$defs": {
    "eval": {
      "type": "object",
      "required": ["id", "prompt", "expected_output", "assertions"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "integer", "minimum": 1},
        "prompt": {"type": "string", "minLength": 1},
        "expected_output": {"type": "string", "minLength": 1},
        "assertions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "files": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
